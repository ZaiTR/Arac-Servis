@page
@model AracServis.Pages.PersonelLoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Personel Giriş</title>

    <style>
        *,
        *::before,
        *::after {
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
            background: #121212;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
        }

        .login-container {
            background: #1e1e1e;
            padding: 2rem;
            border-radius: 12px;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.6);
            width: 100%;
            max-width: 380px;
            margin: 0 auto;
        }

        h2 {
            text-align: center;
            color: #f59e0b;
            margin-bottom: 1.5rem;
        }

        input {
            width: 100%;
            padding: 0.8rem;
            margin-bottom: 1rem;
            border-radius: 6px;
            border: 1px solid #333;
            background: #121212;
            color: #fff;
        }

        button {
            width: 100%;
            padding: 0.8rem;
            background: #f59e0b;
            border: none;
            border-radius: 6px;
            color: #000;
            font-weight: bold;
            cursor: pointer;
        }

        .error {
            color: #ef4444;
            text-align: center;
            margin-top: 10px;
        }
    </style>
</head>

<body>

    <div class="login-container">
        <h2>Personel Giriş</h2>

        <form method="post">
            <input asp-for="KullaniciAdi" placeholder="Kullanıcı Adı" />
            <input asp-for="Sifre" type="password" placeholder="Şifre" />
            <button type="submit">Giriş Yap</button>
        </form>

        <div class="error">
            @Model.HataMesaji
        </div>
    </div>

</body>

</html>